# ─────────────────────────────────────────────────────────────────
# Axion — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com valores do ambiente atual.
# Nunca commite o arquivo .env no repositório.
# ─────────────────────────────────────────────────────────────────

# Supabase — obrigatório e diferente por ambiente
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_publishable_ou_anon_key_aqui

# Compatibilidade com pipelines legados. Prefira VITE_SUPABASE_PUBLISHABLE_KEY.
# VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Ambiente e versão
VITE_APP_ENV=development
VITE_APP_VERSION=local

# Monitoramento — opcional fora de produção
# VITE_SENTRY_DSN=https://public@sentry.example/projeto

# Fase 0 SaaS: OAuth público permanece desligado por padrão.
# Ative somente quando o provedor estiver configurado para não criar contas
# fora do processo oficial de convite/onboarding da organização.
VITE_PUBLIC_OAUTH_ENABLED=false

# Fase 1 SaaS: contexto de organização.
# Mantenha false até aplicar a migration multitenant no ambiente e validar
# memberships, backfill de org_id e RPCs de acesso.
VITE_ORG_TENANCY_ENABLED=false

# Opcional: ativa o bundle analyzer no build
# ANALYZE=true

# ─────────────────────────────────────────────────────────────────
# Supabase Edge Function secrets
# Configure com `supabase secrets set` em cada ambiente.
# Não use o prefixo VITE_ para valores exclusivos do servidor.
# ─────────────────────────────────────────────────────────────────

# Comece em audit durante a preparação de licenças e passe para enforce
# somente após validar os registros de todas as empresas.
AI_USAGE_ENFORCEMENT_MODE=audit

# Limites defensivos de payload e fallback
AI_MAX_PROMPT_CHARS=120000
AI_MAX_FILES=5
AI_MAX_FILE_CHARS=8000000
AI_MAX_TOTAL_FILE_CHARS=20000000
AI_MAX_FALLBACK_PROVIDERS=2
AI_PROVIDER_TIMEOUT_MS=120000

# Origem autorizada pela Edge Function
SITE_URL=http://localhost:5173
